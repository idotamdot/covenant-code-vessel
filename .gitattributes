###############################################################################
# Covenant Code Vessel — Git text normalization
###############################################################################

* text=auto eol=lf

###############################################################################
# Markdown and text files
###############################################################################

*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

###############################################################################
# TypeScript / JavaScript
###############################################################################

*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf

###############################################################################
# Shell / PowerShell
###############################################################################

*.sh text eol=lf
*.ps1 text eol=crlf

###############################################################################
# Binary files
###############################################################################

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.woff binary
*.woff2 binary